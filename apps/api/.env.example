# Server
NODE_ENV=development
PORT=3001
APP_NAME=ForgeInsights AI API
APP_URL=http://localhost:3001

# Database
DATABASE_URL=../../storage/dev.sqlite

# Auth
SESSION_TTL_DAYS=7

# Uploads
UPLOAD_DIR=../../storage/uploads

# AI Provider (openai | azure-openai | nvidia | bedrock | litellm)
AI_PROVIDER=openai
AI_CHAT_MODEL=gpt-4.1-mini
AI_EMBEDDING_PROVIDER=openai
AI_EMBEDDING_MODEL=text-embedding-3-small

# Gateway mode: direct | gateway
AI_GATEWAY_MODE=direct

# LiteLLM Gateway
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
LITELLM_CHAT_MODEL=smart
LITELLM_EMBEDDING_MODEL=embed-default

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# AWS Bedrock
# To use Bedrock: AI_PROVIDER=bedrock AI_EMBEDDING_PROVIDER=bedrock
# AI_CHAT_MODEL and AI_EMBEDDING_MODEL are ignored when using Bedrock
AWS_REGION=eu-west-1
BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_BASE_URL=
NVIDIA_CHAT_MODEL=
NVIDIA_EMBEDDING_MODEL=

# Answers
ANSWER_TOP_K=5
ANSWER_MIN_CHUNKS=2
ANSWER_TEMPERATURE=0

# Retrieval
RETRIEVAL_ENABLE_QUERY_REWRITE=true
RETRIEVAL_REWRITE_MODEL=gpt-4.1-mini
RETRIEVAL_MAX_CANDIDATES=10
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=2
RETRIEVAL_ENABLE_DIVERSITY_RERANK=true
RETRIEVAL_DIVERSITY_LAMBDA=0.7

# Hybrid retrieval
HYBRID_ENABLE_SEMANTIC=true
HYBRID_RRF_K=60
HYBRID_SEMANTIC_CANDIDATES=10

# Observability alerts
ALERT_P95_LATENCY_MS=4000
ALERT_AVG_COST_USD=0.01
ALERT_ERROR_RATE=0.05
ALERT_MIN_RUNS=20
ALERT_REGRESSION_WINDOW_HOURS=24

# Query cache
CACHE_ENABLE_EXACT_QUERY=true
CACHE_TTL_SECONDS=900
CACHE_MAX_ENTRIES=500
RETRIEVAL_SEMANTIC_TIMEOUT_MS=1200
RETRIEVAL_FORCE_LEXICAL_ON_TIMEOUT=true
