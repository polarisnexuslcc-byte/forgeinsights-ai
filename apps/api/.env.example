PORT=3001
NODE_ENV=development
APP_NAME=ForgeInsights AI API
APP_URL=http://localhost:3001
DATABASE_URL=../../storage/dev.sqlite
SESSION_TTL_DAYS=7
UPLOAD_DIR=../../storage/uploads

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANSWER_TOP_K=5
ANSWER_MIN_CHUNKS=2
ANSWER_TEMPERATURE=0

RETRIEVAL_ENABLE_QUERY_REWRITE=true
RETRIEVAL_REWRITE_MODEL=gpt-4.1-mini
RETRIEVAL_MAX_CANDIDATES=10
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=2
RETRIEVAL_ENABLE_DIVERSITY_RERANK=true
RETRIEVAL_DIVERSITY_LAMBDA=0.7

ALERT_P95_LATENCY_MS=4000
ALERT_AVG_COST_USD=0.01
ALERT_ERROR_RATE=0.05
ALERT_MIN_RUNS=20
ALERT_REGRESSION_WINDOW_HOURS=24

CACHE_ENABLE_EXACT_QUERY=true
CACHE_TTL_SECONDS=900
CACHE_MAX_ENTRIES=500
RETRIEVAL_SEMANTIC_TIMEOUT_MS=1200
RETRIEVAL_FORCE_LEXICAL_ON_TIMEOUT=true
